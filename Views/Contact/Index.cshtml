@model HotelBooking.Models.ContactMessage

@{
    ViewData["Title"] = "Contact Us";
}

<link rel="stylesheet" href="~/css/Contact.css" />

<!-- HERO -->
<div class="contact-hero">
    <h1>Contact Us</h1>
    <p>
        We are here to assist you with bookings, inquiries, and special
        requests. Feel free to reach out anytime.
    </p>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success text-center fw-bold">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger text-center fw-bold">
        @TempData["Error"]
    </div>
}

<!-- CONTACT SECTION -->
<div class="container my-5">
    <div class="row g-5 align-items-center">

        <!-- FORM -->
        <div class="col-md-6">
            <div class="contact-card">
                <h3>Send Us a Message</h3>

                <form method="post" asp-controller="Contact" asp-action="Index">
                    @Html.AntiForgeryToken()
                    <!-- Validation Summary -->
                    <div asp-validation-summary="ModelOnly" class="text-danger fw-bold mb-3"></div>

                    <div class="mb-3">
                        <input type="text" class="form-control"
                               asp-for="Name"
                               placeholder="Your Name" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <input type="email" class="form-control"
                               asp-for="Email"
                               placeholder="Your Email" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <input type="text" class="form-control"
                               asp-for="Subject"
                               placeholder="Subject" />
                        <span asp-validation-for="Subject" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <textarea rows="4"
                                  class="form-control"
                                  asp-for="Message"
                                  placeholder="Your Message"></textarea>
                        <span asp-validation-for="Message" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-dark w-100">
                        Send Message
                    </button>
                </form>
            </div>
        </div>

        <!-- DETAILS -->
        <div class="col-md-6">
            <div class="contact-info">

                <h3>Get in Touch</h3>

                <p>
                    📍 <strong>Address:</strong>
                    150 feet Ring Road, Rajkot, Gujarat, India
                </p>

                <p>
                    📞 <strong>Phone:</strong> +91 98765 43210
                </p>

                <p>
                    ✉️ <strong>Email:</strong> info@luxuryhotel.com
                </p>

                <p>
                    🕘 <strong>Reception:</strong> Open 24/7 for your comfort
                </p>

                <!-- MAP -->
                <div class="map-box mt-4">
                    <iframe title="hotel-location"
                            src="https://maps.google.com/maps?q=rajkot%20gujarat%20india&t=&z=13&ie=UTF8&iwloc=&output=embed"
                            width="100%"
                            height="250"
                            style="border:0;"
                            loading="lazy">
                    </iframe>
                </div>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
