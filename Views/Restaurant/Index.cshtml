@{
    ViewData["Title"] = "Restaurant";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold text-primary">Hotel Restaurant</h1>
            <p class="text-muted">Delicious meals by expert chefs</p>
        </div>

        <button type="button" class="btn btn-outline-success" onclick="toggleCart()">
            🛒 Cart (<span id="cartCount">0</span>)
        </button>
    </div>

    <!-- SUCCESS MESSAGE -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success text-center fw-bold">
            @TempData["Success"]
        </div>
    }

    <!-- ERROR MESSAGE -->
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger text-center fw-bold">
            @TempData["Error"]
        </div>
    }

    <!-- CART SECTION -->
    <div id="cartSection" class="card shadow-sm mb-5 d-none">
        <div class="card-body">
            <h4 class="fw-bold text-success mb-3">📋 Your Food Cart</h4>
            <ul id="cartList" class="list-group mb-3"></ul>

            <h5 class="text-end fw-bold text-primary">
                Total: ₹<span id="totalAmount">0</span>
            </h5>
        </div>
    </div>

    <!-- MENUS -->
    <div id="menuContainer"></div>
</div>

<!-- MODAL -->
<div id="restaurantModal" class="d-none"
     style="position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.6);z-index:9999;">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 p-3">

            <div class="modal-header border-0">
                <h5 id="modalTitle" class="text-primary"></h5>
                <button type="button" class="btn-close" onclick="closeModal()"></button>
            </div>

            <div class="modal-body">
                <form id="restaurantBookingForm" method="post"
                      asp-controller="Restaurant" asp-action="BookTable">

                    <input type="hidden" id="tableType" name="tableType" />

                    <label>Select Date</label>
                    <input type="date" class="form-control mb-3"
                           id="bookingDate" name="bookingDate" required />

                    <label>Select Time</label>
                    <input type="time" class="form-control mb-3"
                           id="bookingTime" name="bookingTime" required />

                    <label>Guests</label>
                    <input type="number" class="form-control"
                           id="guests" name="guests" required min="1" max="20" />
                </form>
            </div>

            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" onclick="closeModal()">Cancel</button>

                <button type="button" class="btn btn-success" onclick="confirmBooking()">
                    Confirm Booking
                </button>
            </div>

        </div>
    </div>
</div>

@section Scripts {

<script>
           window.openModal = function (type) {
            document.getElementById("modalTitle").innerText = "🍽️ Book " + type;
            document.getElementById("tableType").value = type;
            document.getElementById("restaurantModal").classList.remove("d-none");
        }

        window.closeModal = function () {
            document.getElementById("restaurantModal").classList.add("d-none");
            document.getElementById("bookingDate").value = "";
            document.getElementById("bookingTime").value = "";
            document.getElementById("guests").value = "";
        }

        window.confirmBooking = function () {
            let date = document.getElementById("bookingDate").value;
            let time = document.getElementById("bookingTime").value;
            let guests = document.getElementById("guests").value;

            if (!date || !time || !guests) {
                alert("⚠️ Please fill all fields");
                return;
            }

            document.getElementById("restaurantBookingForm").submit();
        }

</script>


<script>
    // CART STATE (replacement of useState)
    let cart = [];
    let showCart = false;

    // MENU DATA (converted from React)
    const menuData = [
        {
            category: "🍳 Breakfast Menu",
            items: [
                { name: "Chai", price: 30, img: "https://th.bing.com/th/id/OIP.5QGhesW0p3wLCmwGhNckVwHaHa?w=181&h=182&c=7" },
                { name: "Coffee", price: 60, img: "https://th.bing.com/th/id/OIP.LHQzdJOlbCJ7l9jE-KXUZAHaE4?w=271&h=180&c=7" },
                { name: "Gujarati Thepla", price: 40, img: "https://th.bing.com/th/id/OIP.9oUnTqUa1BpspbcgV2RJeQHaE8?w=300&h=200&c=7" },
                { name: "Masala Dosa", price: 120, img: "data:image/webp;base64," },
                { name: "Idli Sambhar", price: 90, img: "https://images.unsplash.com/photo-1610192244261-3f33de3f55e4" },
                { name: "Mendu Vada", price: 90, img: "https://th.bing.com/th/id/OIP.2RYGURfORWGaT8sfbN-aRQHaHa?w=200&h=200&c=7" },
                { name: "Poha", price: 80, img: "https://th.bing.com/th/id/OIP.RPb1V_81tD4VcG-MLM3fNgHaFj?w=250&h=187&c=7" },
                { name: "Pancakes", price: 150, img: "data:image/webp;base64," }
            ]
        },
        {
            category: "🍛 Lunch Menu",
            items: [
                { name: "Veg Thali", price: 220, img: "data:image/webp;base64," },
                { name: "Paneer Butter Masala", price: 250, img: "https://images.unsplash.com/photo-1631452180519-c014fe946bc7" },
                { name: "Dal Tadka", price: 200, img: "data:image/webp;base64," },
                { name: "Butter Naan", price: 90, img: "https://th.bing.com/th/id/OIP.l7a8rTmoZJT601nGpe5TvAHaHa?w=176&h=180&c=7" }
            ]
        },
        {
            category: "🍽️ Dinner Menu",
            items: [
                { name: "Veg Biryani", price: 280, img: "https://th.bing.com/th/id/OIP.9Ukx4bH1XJkL2KWy9ffn3gHaFj?w=246&h=185&c=7" },
                { name: "Paneer Tikka", price: 320, img: "https://th.bing.com/th/id/OIP.KCNhiQeXsJuIzDEJtxA57gHaFS?w=222&h=181&c=7" },
                { name: "Mix Veg Curry", price: 240, img: "https://th.bing.com/th/id/OIP.H9_9Tll5xet50Q-QvJby-gHaE7?w=257&h=180&c=7" },
                { name: "Tandoori Roti", price: 70, img: "data:image/webp;base64," }
            ]
        }
    ];

    // RENDER MENU
    const menuContainer = document.getElementById("menuContainer");

    menuData.forEach(section => {
        let html = `<h3 class="mb-3">${section.category}</h3><div class="row mb-5">`;

        section.items.forEach(item => {
            html += `
                <div class="col-md-3 mb-4">
                    <div class="card shadow h-100">
                        <img src="${item.img || 'https://via.placeholder.com/300'}"
                             class="card-img-top"
                             style="height:200px;object-fit:cover;">
                        <div class="card-body text-center">
                            <h5>${item.name}</h5>
                            <p class="text-success fw-semibold">₹${item.price}</p>
                                <div class="d-flex justify-content-between">

                            <!-- BOOK NOW -->
                            <button class="btn btn-primary btn-sm"
                                style="padding:7px 13px;font-size:13px"
                                    onclick="openModal('${item.name}', ${item.price})">
                                🔘 Book Now
                            </button>

                            <!-- ADD TO LIST -->
                            <button class="btn btn-outline-success btn-sm"
                                style="padding:7px 13px;font-size:13px"
                                    onclick="addToCart('${item.name}', ${item.price})">
                                🛒 Add to List
                            </button>

                        </div>

                        </div>
                    </div>
                </div>`;
        });

        html += "</div>";
        menuContainer.innerHTML += html;
    });

    // CART FUNCTIONS
    function addToCart(item) {
        cart.push(item);
        updateCart();
    }

    function orderNow(name) {
        alert("✅ Order placed for " + name);
    }

    function toggleCart() {
        showCart = !showCart;
        document.getElementById("cartSection").style.display = showCart ? "block" : "none";
    }

    function updateCart() {
        const cartList = document.getElementById("cartList");
        const cartCount = document.getElementById("cartCount");
        const totalAmount = document.getElementById("totalAmount");

        cartList.innerHTML = "";
        let total = 0;

        cart.forEach(item => {
            total += item.price;
            cartList.innerHTML += `
                <li class="list-group-item d-flex justify-content-between">
                    <span>${item.name}</span>
                    <strong>₹${item.price}</strong>
                </li>`;
        });

        cartCount.innerText = cart.length;
        totalAmount.innerText = total;
    }
</script>
}
