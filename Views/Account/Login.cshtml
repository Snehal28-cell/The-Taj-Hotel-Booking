@model HotelBooking.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div style="
     min-height:100vh;
     background:linear-gradient(135deg,#667eea,#764ba2);
     display:flex;
     align-items:center;
     justify-content:center;
">
    <div class="card shadow-lg p-4 rounded-4" style="width:400px">

        <h3 class="text-center fw-bold">Welcome Back</h3>
        <p class="text-center text-muted">Login to continue</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">
                @ViewBag.Error
            </div>
        }

        <form method="post"
              asp-action="Login"
              asp-controller="Account">

            <input class="form-control mb-3"
                   name="email"
                   placeholder="Email"
                   value="@Model?.Email"
                   required />

            <input type="password"
                   class="form-control mb-3"
                   name="password"
                   placeholder="Password"
                   required />

            <button class="btn btn-dark w-100 rounded-pill">
                Login
            </button>

        </form>
    </div>
</div>
