@model List<HotelBooking.Models.ContactMessage>

@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container mt-4">

    <h2 class="mb-4">Contact Messages</h2>

    <div class="d-flex gap-2 mb-3">

        <input id="searchBox"
               class="form-control"
               placeholder="Search name..." />

        <select id="statusFilter"
                class="form-select"
                style="width:180px">

            <option value="All">All</option>
            <option value="Pending">Pending</option>
            <option value="Confirmed">Confirmed</option>

        </select>

    </div>

    <div style="max-height:500px;overflow-y:auto">

        <table class="table bg-white shadow-sm" id="contactTable">

            <thead class="table-dark sticky-top">

                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th style="width:260px">Actions</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var m in Model)
                {

                    <tr data-status="@m.Status">

                        <td class="name">@m.Name</td>

                        <td>@m.Email</td>

                        <td>

                            <span class="badge rounded-pill px-3
    @(m.Status == "Confirmed" ? "bg-success" : "bg-warning text-dark")">

                                @m.Status

                            </span>

                        </td>

                        <td>

                            <button class="btn btn-sm btn-success me-2 action-btn"
                                    onclick="changeStatus(@m.Id,'Confirmed')">

                                Confirm

                            </button>

                            <button class="btn btn-sm btn-secondary me-2 action-btn"
                                    onclick="changeStatus(@m.Id,'Pending')">

                                Pending

                            </button>

                            <button class="btn btn-sm btn-danger action-btn"
                                    onclick="deleteMessage(@m.Id)">

                                Delete

                            </button>

                        </td>

                    </tr>

                }

            </tbody>

        </table>

    </div>

</div>

<script>

    function changeStatus(id,status){

    $.post("/AdminContact/ChangeStatus",
    { id:id, status:status },
    function(){
    location.reload();
    });

    }

    function deleteMessage(id){

    if(!confirm("Delete message?")) return;

    $.post("/AdminContact/Delete",
    { id:id },
    function(){
    location.reload();
    });

    }

    $("#searchBox").on("keyup",function(){

    var value=$(this).val().toLowerCase();

    $("#contactTable tbody tr").filter(function(){

    $(this).toggle($(this).find(".name").text().toLowerCase().indexOf(value)>-1)

    });

    });

    $("#statusFilter").on("change",function(){

    var value=$(this).val();

    $("#contactTable tbody tr").each(function(){

    var status=$(this).data("status");

    if(value=="All" || status==value){
    $(this).show();
    }else{
    $(this).hide();
    }

    });

    });

</script>

<style>

    .action-btn{
    transition:0.2s;
    }

    .action-btn:hover{
    transform:translateY(-2px);
    box-shadow:0 4px 10px rgba(0,0,0,.2);
    }

</style>