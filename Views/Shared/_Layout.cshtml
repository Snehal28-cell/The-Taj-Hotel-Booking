        <nav class="navbar navbar-expand-lg navbar-dark shadow-sm">
            <div class="container-fluid">

                <!-- Logo -->
                <a class="navbar-brand d-flex align-items-center gap-2"
                   asp-controller="Home"
                   asp-action="Index">

                    <img src="~/images/logo.jpeg"
                         alt="The Taj Logo"
                         class="taj-logo" />

                    <span class="fw-bold fs-4">The Taj</span>
                </a>

                <!-- Toggle Button -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Center Menu -->
                <div class="collapse navbar-collapse justify-content-center" id="mainNavbar">
                    <ul class="navbar-nav gap-3">

                        <li class="nav-item">
                            <a class="nav-link active"
                               asp-controller="Home"
                               asp-action="Index">
                                Home
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Rooms" asp-action="Index">Rooms</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Restaurant"
                               asp-action="Index">
                                Restaurant
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Spa"
                               asp-action="Index">
                                Spa
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Contact"
                               asp-action="Index">
                                Contact
                            </a>
                        </li>

                    </ul>
                </div>

                <!-- RIGHT SIDE BUTTONS -->
                <div class="ms-auto d-flex gap-3">

                    @* <a class="btn btn-login btn-sm"
                       asp-controller="Account"
                       asp-action="Login">
                        Login
                    </a> *@
                    <a class="btn btn-login btn-sm" asp-controller="Account" asp-action="Login">
                        Login
                    </a>

                    <a class="btn btn-register btn-sm" asp-controller="Account" asp-action="Register">
                        Register
                    </a>

                    @* <a class="btn btn-register btn-sm"
                       asp-controller="Account"
                       asp-action="Register">
                        Register
                    </a> *@

                </div>

            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @* <footer class="border-top footer text-muted">
        <div class="container">
