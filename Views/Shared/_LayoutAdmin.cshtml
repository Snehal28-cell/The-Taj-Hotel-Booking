@{
    <!DOCTYPE html>
    <html>
    <head>

        <meta name="viewport" content="width=device-width" />

        <title>@ViewData["Title"]</title>

        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

        <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

        <style>

            body {
                transition: 0.3s;
                background: #f4f6f9;
            }

            .dark-mode {
                background: #121212;
                color: white;
            }

            .sidebar {
                position: fixed;
                width: 230px;
                height: 100vh;
                background: #111;
                color: white;
                padding-top: 20px;
            }

                .sidebar a {
                    display: block;
                    padding: 12px 20px;
                    color: #bbb;
                    text-decoration: none;
                }

                    .sidebar a:hover {
                        background: #222;
                        color: white;
                    }

            .content {
                margin-left: 230px;
                padding: 20px;
            }

            .card-dashboard {
                border: none;
                border-radius: 12px;
                box-shadow: 0 4px 12px rgba(0,0,0,.15);
                transition: 0.3s;
            }

                .card-dashboard:hover {
                    transform: translateY(-5px);
                }

        </style>

    </head>

    <body>

        <div class="sidebar">

            <h4 class="text-center text-danger mb-4">
                <i class="fa-solid fa-hotel"></i> Hotel Admin
            </h4>

            <a href="/Admin/Dashboard">
                <i class="fa-solid fa-chart-line"></i> Dashboard
            </a>

            <a asp-controller="AdminBookings" asp-action="Index">
                <i class="fa-solid fa-calendar-check"></i> Bookings
            </a>

            <a asp-controller="AdminRestaurant" asp-action="Index">
                <i class="fa-solid fa-utensils"></i> Restaurant
            </a>

            <a asp-controller="AdminSpa" asp-action="Index">
                <i class="fa-solid fa-spa"></i> Spa
            </a>

            <a asp-controller="AdminContact" asp-action="Index">
                <i class="fa-solid fa-chart-pie"></i> Contact
            </a>

        </div>

        <div class="content">

            <div class="d-flex justify-content-between mb-3">

                <h5>Admin Dashboard</h5>

                <button class="btn btn-sm btn-dark" onclick="toggleTheme()">
                    Toggle Theme
                </button>

            </div>

            @RenderBody()

        </div>

        @RenderSection("Scripts", required: false)

        <script>

            function toggleTheme(){
            document.body.classList.toggle("dark-mode");
            }

        </script>

    </body>
    </html>
}
