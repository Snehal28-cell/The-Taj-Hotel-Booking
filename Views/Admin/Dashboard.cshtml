@model HotelBooking.Models.AdminDashboardViewModel
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<link rel="stylesheet" href="~/css/AdminDashboard.css" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

<div class="container-fluid admin-wrapper">

    <!-- HEADER -->
    <div class="admin-header">
        <div>
            <h3>Welcome Admin 👋</h3>
            <p>Luxury Hotel Management Dashboard</p>
        </div>

        <div class="d-flex gap-2">

            <!-- THEME TOGGLE -->
            @* <button class="btn-theme" onclick="toggleTheme()">
                🌙 Toggle Theme
            </button> *@

            <button class="btn-download">
                ⬇ Download Report
            </button>

        </div>
    </div>

    <!-- STATS -->
    <div class="row g-3 mt-2">

        <div class="col-md-3">
            <div class="stat-card blue">
                <div>
                    <div class="label">Total Rooms</div>
                    <div class="value">45</div>
                </div>
                <i class="fa fa-bed icon"></i>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card green">
                <div>
                    <div class="label">Bookings</div>
                    <div class="value">120</div>
                </div>
                <i class="fa fa-calendar-check icon"></i>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card orange">
                <div>
                    <div class="label">Orders</div>
                    <div class="value">32</div>
                </div>
                <i class="fa fa-utensils icon"></i>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card red">
                <div>
                    <div class="label">Revenue</div>
                    <div class="value">₹85K</div>
                </div>
                <i class="fa fa-indian-rupee-sign icon"></i>
            </div>
        </div>

    </div>

    <!-- MAIN -->
    <div class="row mt-4">

        <!-- CHART -->
        <div class="col-lg-8 mb-3">
            <div class="card-box">
                <h5>Weekly Bookings Overview</h5>
                <canvas id="bookingChart" height="120"></canvas>
            </div>
        </div>

        <!-- SIDE PANEL -->
        <div class="col-lg-4">

            <div class="card-box mb-3">
                <h6>Live Activity <span class="live">LIVE</span></h6>

                <div class="activity">✔ New booking - Room 203</div>
                <div class="activity">✔ Payment received ₹4,500</div>
                <div class="activity">✔ Room cleaned 105</div>
                <div class="activity">✔ Restaurant order placed</div>

            </div>

            <div class="card-box">
                <h6>Quick Actions</h6>

                <!-- FIXED BUTTONS -->
                <a href="/Admin/AddRoom" class="btn btn-primary w-100 mb-2">
                    + Add Room
                </a>

                <a href="/Admin/ViewRooms" class="btn btn-success w-100 mb-2">
                    View Rooms
                </a>

                <a href="/Admin/Reports" class="btn btn-dark w-100">
                    Reports
                </a>

            </div>

        </div>

    </div>

</div>

<!-- SCRIPT -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    /* CHART */
    const ctx = document.getElementById('bookingChart');

    new Chart(ctx, {
        type: 'line',
        data: {
            labels: ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'],
            datasets: [{
                label: 'Bookings',
                data: [10, 15, 12, 18, 25, 22, 30],
                borderColor: '#6366f1',
                backgroundColor: 'rgba(99,102,241,0.2)',
                fill: true,
                tension: 0.4
            }]
        },
        options: {
            plugins: { legend: { display: false } }
        }
    });

    /* ================= THEME TOGGLE ================= */

    // function toggleTheme() {
    //     document.body.classList.toggle("light-mode");

    //     localStorage.setItem(
    //         "theme",
    //         document.body.classList.contains("light-mode") ? "light" : "dark"
    //     );
    // }

    /* load saved theme */
    window.onload = function () {
        if (localStorage.getItem("theme") === "light") {
            document.body.classList.add("light-mode");
        }
    };
</script>