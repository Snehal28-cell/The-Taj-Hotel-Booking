@model HotelBooking.Models.AdminDashboardViewModel
@* @{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="container-fluid p-4 bg-light min-vh-100">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold">Welcome, Admin 👋</h3>
            <p class="text-muted mb-0">Manage your hotel bookings easily</p>
        </div>
        <button class="btn btn-primary">⬇ Download Report</button>
    </div>

    <!-- CARDS -->
    <div class="row g-4">
        @{
            var cards = new[]
            {
                new { Title="Total Bookings", Value=Model.TotalBookings, Color="#4f46e5", Icon="📅"},
                new { Title="Spa Bookings", Value=Model.SpaBookings, Color="#10b981", Icon="💆"},
                new { Title="Restaurant Orders", Value=Model.RestaurantOrders, Color="#f59e0b", Icon="🍽"},
                new { Title="Messages", Value=Model.Contacts, Color="#ef4444", Icon="📩"},
                };
        }

        @foreach (var card in cards)
        {
            <div class="col-lg-3 col-md-6">
                <div class="p-4 bg-white rounded shadow-sm" style="border-left:5px solid @card.Color">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="text-muted">@card.Title</h6>
                            <h3 class="fw-bold counter" data-target="@card.Value">0</h3>
                            <small class="text-muted">Updated today</small>
                        </div>
                        <div style="font-size:28px">@card.Icon</div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- CHART + CALENDAR -->
    <div class="row mt-4">

        <div class="col-lg-8 mb-4">
            <div class="bg-white p-4 rounded shadow-sm">
                <h5 class="fw-bold mb-3">📊 Revenue Statistics</h5>
                <canvas id="revenueChart"></canvas>
            </div>
        </div>

        <div class="col-lg-4 mb-4">
            <div class="bg-white p-4 rounded shadow-sm text-center">
                <h5 class="fw-bold mb-3">📅 Booking Schedule</h5>

                <input type="date" class="form-control mb-3" />

                <div class="alert alert-info">
                    Today Check-ins: <strong>@Model.TodayCheckins</strong>
                </div>
            </div>
        </div>

    </div>

    <!-- BOOKINGS TABLE -->
    <div class="bg-white p-4 rounded shadow-sm">
        <h5 class="fw-bold mb-3">📋 Recent Bookings</h5>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Room</th>
                        <th>Check In</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.RecentBookings != null && Model.RecentBookings.Count > 0)
                    {
                        @foreach (var b in Model.RecentBookings)
                        {
                            <tr>
                                <td>@b.RoomType</td>
                                <td>@b.CheckIn</td>
                                <td><span class="badge bg-success">Completed</span></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center">No bookings yet</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

@section Scripts {

    <script>
        // COUNT UP ANIMATION
        document.querySelectorAll(".counter").forEach(counter => {
            let update = () => {
                let target = +counter.getAttribute("data-target");
                let current = +counter.innerText;
                let increment = target / 50;

                if (current < target) {
                    counter.innerText = Math.ceil(current + increment);
                    setTimeout(update, 20);
                } else {
                    counter.innerText = target;
                }
            };
            update();
        });

        // CHART JS
        var ctx = document.getElementById('revenueChart').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ["Jan", "Feb", "Mar", "Apr", "May", "Jun"],
                datasets: [{
                    label: "Revenue",
                    data: [1200, 1900, 800, 2400, 1800, 1500],
                    backgroundColor: "#4f46e5",
                    borderRadius: 10
                }]
            }
        });

        // AUTO REFRESH LIKE useEffect
        setInterval(function () {
            location.reload();
        }, 15000);

    </script>

} *@

@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="row mb-4">

    <div class="col-md-3">
        <div class="card card-dashboard bg-primary text-white p-3">
            <h6>Total Rooms</h6>
            <h2 id="roomsCount">45</h2>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card card-dashboard bg-success text-white p-3">
            <h6>Total Bookings</h6>
            <h2 id="bookingCount">120</h2>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card card-dashboard bg-warning text-dark p-3">
            <h6>Restaurant Orders</h6>
            <h2>32</h2>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card card-dashboard bg-danger text-white p-3">
            <h6>Revenue</h6>
            <h2>₹85,000</h2>
        </div>
    </div>

</div>


<div class="card p-3">

    <h5>Weekly Bookings</h5>

    <canvas id="bookingChart"></canvas>

</div>


@section Scripts {

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>

        /* Chart.js Graph */

        const ctx = document.getElementById('bookingChart');

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'],
                datasets: [{
                    label: 'Bookings',
                    data: [10,15,12,18,25,22,30]
                }]
            }
        });


        /* SignalR Live Booking Updates */

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/bookingHub")
            .build();

        connection.on("ReceiveBooking", function (message) {

            alert("New Booking: " + message);

        });

        connection.start();

    </script>

}